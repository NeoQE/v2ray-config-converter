<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>V2Ray Server Tool</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;600;700&family=Vazirmatn:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #070b0f;
    --surface: #0d1117;
    --surface2: #161b22;
    --border: #1e2836;
    --accent: #00d4aa;
    --accent2: #0aff9d;
    --accent-dim: rgba(0, 212, 170, 0.12);
    --accent-glow: 0 0 20px rgba(0, 212, 170, 0.3);
    --red: #ff4757;
    --red-dim: rgba(255, 71, 87, 0.12);
    --yellow: #f2cc60;
    --blue: #79c0ff;
    --purple: #d2a8ff;
    --orange: #ffa657;
    --text: #c9d1d9;
    --text-dim: #58677a;
    --text-bright: #e6edf3;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Vazirmatn', sans-serif;
    --radius: 14px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,212,170,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,212,170,0.025) 1px, transparent 1px);
    background-size: 44px 44px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    top: -180px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(0,212,170,0.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 980px;
    margin: 0 auto;
    padding: 40px 20px 80px;
  }

  /* ── Header ── */
  .header {
    text-align: center;
    margin-bottom: 48px;
    animation: fadeDown 0.6s ease both;
  }

  .logo-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent-dim);
    border: 1px solid rgba(0,212,170,0.2);
    border-radius: 100px;
    padding: 6px 18px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .logo-badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent);
    animation: pulse 2s infinite;
  }

  h1 {
    font-size: clamp(28px, 5vw, 50px);
    font-weight: 700;
    color: var(--text-bright);
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 10px;
  }

  h1 span { color: var(--accent); text-shadow: var(--accent-glow); }

  .subtitle {
    color: var(--text-dim);
    font-size: 14.5px;
    font-weight: 300;
    line-height: 1.6;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Section tabs ── */
  .section-tabs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 30px;
    animation: fadeDown 0.8s ease both;
    animation-delay: 0.1s;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 20px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: var(--surface2);
    color: var(--text-dim);
    font-family: var(--sans);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tab-btn.active {
    background: var(--accent-dim);
    border-color: rgba(0,212,170,0.35);
    color: var(--accent);
  }

  .tab-btn:hover:not(.active) {
    border-color: rgba(0,212,170,0.2);
    color: var(--text);
  }

  /* ── Card ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.55);
    animation: fadeUp 0.7s ease both;
    animation-delay: 0.15s;
    display: none;
  }
  .card.active { display: block; }

  .card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
  }

  .traffic-lights { display: flex; gap: 6px; }
  .traffic-lights span { width: 12px; height: 12px; border-radius: 50%; }
  .tl-red { background: #ff5f56; }
  .tl-yellow { background: #febc2e; }
  .tl-green { background: #28c840; }

  .card-title {
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--text-dim);
    letter-spacing: 1px;
    flex: 1;
    text-align: center;
  }

  /* ── ONE-TIME SETUP BANNER ── */
  .onetime-banner {
    margin: 18px 22px 0;
    border: 1px solid rgba(242,204,96,0.25);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(242,204,96,0.03);
  }

  .onetime-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: rgba(242,204,96,0.07);
    border-bottom: 1px solid rgba(242,204,96,0.15);
    cursor: pointer;
    user-select: none;
  }

  .onetime-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(242,204,96,0.12);
    border: 1px solid rgba(242,204,96,0.3);
    border-radius: 6px;
    padding: 2px 9px;
    font-family: var(--mono);
    font-size: 9.5px;
    color: var(--yellow);
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 700;
    flex-shrink: 0;
  }

  .onetime-badge::before {
    content: '';
    width: 5px; height: 5px;
    background: var(--yellow);
    border-radius: 50%;
    box-shadow: 0 0 6px var(--yellow);
  }

  .onetime-title {
    font-size: 12.5px;
    font-weight: 600;
    color: #d4b96a;
    flex: 1;
  }

  .onetime-toggle {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--text-dim);
    transition: transform 0.2s;
  }

  .onetime-toggle.open { transform: rotate(180deg); }

  .onetime-body {
    padding: 12px 14px 14px;
    display: none;
  }
  .onetime-body.open { display: block; }

  .onetime-desc {
    font-size: 12px;
    color: var(--text-dim);
    margin-bottom: 10px;
    line-height: 1.6;
  }

  .onetime-desc strong { color: var(--yellow); }

  .onetime-cmd {
    background: var(--bg);
    border: 1px solid rgba(242,204,96,0.15);
    border-radius: 8px;
    padding: 12px 14px;
    font-family: var(--mono);
    font-size: 11.5px;
    line-height: 1.7;
    color: #c8b97a;
    direction: ltr;
    white-space: pre;
    overflow: auto;
    max-height: 180px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .onetime-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .onetime-note {
    font-size: 11px;
    color: var(--text-dim);
    font-family: var(--mono);
  }

  /* ── Input area ── */
  .input-section { padding: 22px 22px 6px; }

  .input-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-bright);
  }

  .tag {
    background: var(--accent-dim);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 9.5px;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 1px;
  }

  .tag-orange {
    background: rgba(255,166,87,0.12);
    color: var(--orange);
  }

  .tag-purple {
    background: rgba(210,168,255,0.12);
    color: var(--purple);
  }

  .tag-yellow {
    background: rgba(242,204,96,0.12);
    color: var(--yellow);
  }

  textarea {
    width: 100%;
    min-height: 180px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.65;
    padding: 14px;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    direction: ltr;
    tab-size: 2;
  }

  textarea::placeholder { color: var(--text-dim); opacity: 0.5; }

  textarea:focus {
    border-color: rgba(0,212,170,0.4);
    box-shadow: 0 0 0 3px rgba(0,212,170,0.06);
  }

  /* ── Hint ── */
  .hint {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 12px 0 0;
    padding: 12px 14px;
    background: rgba(255,184,0,0.04);
    border: 1px solid rgba(255,184,0,0.14);
    border-radius: 8px;
    font-size: 12px;
    color: #a8956a;
    line-height: 1.6;
  }

  .hint code {
    font-family: var(--mono);
    background: rgba(255,184,0,0.1);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 11px;
  }

  /* Install type selector */
  .install-type-row {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .type-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface2);
    color: var(--text-dim);
    font-size: 12.5px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--sans);
  }

  .type-chip.selected {
    border-color: rgba(0,212,170,0.4);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .type-chip:hover:not(.selected) {
    border-color: rgba(0,212,170,0.2);
    color: var(--text);
  }

  /* ── Actions ── */
  .actions {
    padding: 16px 22px 22px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    border: none;
    border-radius: 9px;
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    letter-spacing: 0.2px;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--accent);
    color: #000;
    box-shadow: 0 4px 20px rgba(0,212,170,0.22);
  }
  .btn-primary:hover {
    background: var(--accent2);
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(0,212,170,0.38);
  }
  .btn-primary:active { transform: translateY(0); }

  .btn-orange {
    background: var(--orange);
    color: #000;
    box-shadow: 0 4px 20px rgba(255,166,87,0.22);
  }
  .btn-orange:hover {
    background: #ffb86c;
    transform: translateY(-1px);
    box-shadow: 0 6px 28px rgba(255,166,87,0.38);
  }

  .btn-yellow {
    background: var(--yellow);
    color: #000;
    box-shadow: 0 4px 20px rgba(242,204,96,0.22);
  }
  .btn-yellow:hover {
    background: #f5d96e;
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border);
  }
  .btn-ghost:hover {
    color: var(--text);
    border-color: rgba(0,212,170,0.3);
  }

  .btn:disabled { opacity: 0.35; cursor: not-allowed; transform: none !important; }

  /* ── Error ── */
  .error-box {
    display: none;
    align-items: flex-start;
    gap: 10px;
    margin: 0 22px 16px;
    padding: 12px 14px;
    background: var(--red-dim);
    border: 1px solid rgba(255,71,87,0.25);
    border-radius: 8px;
    font-size: 12.5px;
    color: var(--red);
    animation: shake 0.3s ease;
    line-height: 1.5;
    direction: rtl;
  }
  .error-box.visible { display: flex; }

  /* ── Divider ── */
  .divider {
    margin: 0 22px;
    border: none;
    border-top: 1px solid var(--border);
  }

  /* ── Info bar ── */
  .info-bar {
    display: none;
    gap: 0;
    flex-direction: column;
    margin: 0 22px 16px;
    background: var(--bg);
    border: 1px solid rgba(0,212,170,0.18);
    border-radius: 10px;
    overflow: hidden;
    font-family: var(--mono);
    font-size: 11.5px;
  }
  .info-bar.visible { display: flex; }

  .info-bar-title {
    background: rgba(0,212,170,0.07);
    border-bottom: 1px solid rgba(0,212,170,0.12);
    padding: 8px 14px;
    color: var(--accent);
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .info-rows { padding: 10px 14px; display: flex; flex-direction: column; gap: 6px; }

  .info-row {
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  .info-key {
    color: var(--blue);
    min-width: 110px;
    flex-shrink: 0;
    font-size: 11px;
  }

  .info-val {
    color: #a5d6ff;
    word-break: break-all;
  }

  .info-val.highlight {
    color: var(--accent2);
    font-weight: 600;
  }

  /* ── Output section ── */
  .output-section { padding: 22px; display: none; animation: fadeUp 0.4s ease; }
  .output-section.visible { display: block; }

  .output-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    gap: 10px;
    flex-wrap: wrap;
  }

  .output-label-left {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-bright);
  }

  .output-label-left .tag {
    background: rgba(10,255,157,0.1);
    color: var(--accent2);
    letter-spacing: 1px;
  }

  .output-label-left .tag-orange {
    background: rgba(255,166,87,0.12);
    color: var(--orange);
    letter-spacing: 1px;
  }

  .output-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

  .icon-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    border-radius: 6px;
    padding: 5px 11px;
    font-size: 11.5px;
    cursor: pointer;
    font-family: var(--sans);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .icon-btn:hover { border-color: var(--accent); color: var(--accent); }
  .icon-btn.copied { border-color: var(--accent2); color: var(--accent2); background: rgba(10,255,157,0.05); }

  .output-box {
    background: var(--bg);
    border: 1px solid rgba(0,212,170,0.18);
    border-radius: 10px;
    padding: 14px 16px;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 1.7;
    color: #8fbfbd;
    direction: ltr;
    overflow: auto;
    white-space: pre;
    max-height: 440px;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    box-shadow: inset 0 0 40px rgba(0,212,170,0.015);
  }

  .output-box-install {
    border-color: rgba(255,166,87,0.2);
    box-shadow: inset 0 0 40px rgba(255,166,87,0.01);
  }

  .output-box::-webkit-scrollbar { width: 4px; height: 4px; }
  .output-box::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* JSON syntax */
  .json-key { color: #79c0ff; }
  .json-string { color: #a5d6ff; }
  .json-number { color: #f2cc60; }
  .json-bool { color: #ff9580; }
  .json-null { color: #ff9580; }

  /* bash syntax */
  .bash-cmd { color: #f2cc60; font-weight: 600; }
  .bash-flag { color: var(--orange); }
  .bash-str { color: #a5d6ff; }
  .bash-comment { color: var(--text-dim); font-style: italic; }
  .heredoc-cmd { color: #f2cc60; font-weight: 600; }
  .heredoc-eof { color: #ff9580; font-weight: 700; letter-spacing: 1px; }

  .download-row {
    margin-top: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* ── Stats bar ── */
  .stats-bar {
    display: flex;
    gap: 16px;
    padding: 12px 22px;
    background: var(--surface2);
    border-top: 1px solid var(--border);
    font-size: 11.5px;
    color: var(--text-dim);
    font-family: var(--mono);
    flex-wrap: wrap;
    align-items: center;
  }

  .stat { display: flex; align-items: center; gap: 6px; }

  .stat-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
    flex-shrink: 0;
  }
  .stat-dot.inactive { background: var(--text-dim); box-shadow: none; }
  .stat-dot.orange { background: var(--orange); box-shadow: 0 0 6px var(--orange); }
  .stat-dot.yellow { background: var(--yellow); box-shadow: 0 0 6px var(--yellow); }

  /* ── Install type badge ── */
  .install-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: 6px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 1px;
    text-transform: uppercase;
    font-weight: 700;
  }

  .install-badge.github {
    background: rgba(210,168,255,0.1);
    color: var(--purple);
    border: 1px solid rgba(210,168,255,0.2);
  }

  .install-badge.apt {
    background: rgba(255,166,87,0.1);
    color: var(--orange);
    border: 1px solid rgba(255,166,87,0.2);
  }

  .install-badge.pip {
    background: rgba(121,192,255,0.1);
    color: var(--blue);
    border: 1px solid rgba(121,192,255,0.2);
  }

  .install-badge.curl {
    background: rgba(0,212,170,0.1);
    color: var(--accent);
    border: 1px solid rgba(0,212,170,0.2);
  }

  /* ── Quick Commands Card ── */
  .quick-card {
    margin-top: 28px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    animation: fadeUp 0.85s ease both;
    animation-delay: 0.2s;
    position: relative;
  }

  .quick-header {
    padding: 16px 20px 12px;
    background: linear-gradient(135deg, rgba(0,212,170,0.06) 0%, rgba(121,192,255,0.04) 100%);
    border-bottom: 1px solid var(--border);
  }

  .quick-title {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 700;
    color: var(--text-bright);
    margin-bottom: 3px;
  }

  .quick-subtitle {
    font-size: 11.5px;
    color: var(--text-dim);
    font-weight: 400;
  }

  .quick-tabs {
    display: flex;
    gap: 4px;
    padding: 10px 12px 0;
    border-bottom: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }
  .quick-tabs::-webkit-scrollbar { display: none; }

  .qtab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 13px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: all 0.18s;
    white-space: nowrap;
    border-radius: 6px 6px 0 0;
  }

  .qtab:hover { color: var(--text); background: rgba(255,255,255,0.02); }

  .qtab.active {
    color: var(--text-bright);
    border-bottom-color: var(--accent);
    background: var(--accent-dim);
  }

  .qdot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .qdot-green { background: #28c840; box-shadow: 0 0 5px rgba(40,200,64,0.5); }
  .qdot-red { background: #ff5f56; box-shadow: 0 0 5px rgba(255,95,86,0.5); }
  .qdot-blue { background: #79c0ff; box-shadow: 0 0 5px rgba(121,192,255,0.5); }
  .qdot-yellow { background: var(--yellow); box-shadow: 0 0 5px rgba(242,204,96,0.5); }

  .quick-pane {
    display: none;
    padding: 14px 18px 16px;
    position: relative;
    animation: fadeIn 0.25s ease;
  }
