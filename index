  const cleaned = raw.replace(/\[([^\]]+)\]\([^)]+\)/g, (m, t) => t.trim());
  const normalized = cleaned.replace(/\r\n/g, '\n').replace(/\r/g, '\n');
  let result = tryEOF(normalized) || tryJSON(normalized) || tryVlessLink(normalized)
             || tryVmessLink(normalized) || tryTrojanLink(normalized)
             || trySsLink(normalized) || tryBracketExtract(normalized);

