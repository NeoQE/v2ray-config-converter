  try {
    parsedConfigJSON = typeof result === 'string' ? JSON.parse(result) : result;
    parsedConfigJSON = cleanMarkdownInJSON(parsedConfigJSON);
    const pretty = JSON.stringify(parsedConfigJSON, null, 2);
