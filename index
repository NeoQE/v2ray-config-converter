function detectInstallType(val) {
  if (!val) return null;
  if (val.includes('github.com') || val.includes('githubusercontent.com') || val.includes('raw.github')) {
    return 'github';
  }
  if (/^https?:\/\//.test(val)) return 'url';
  if (selectedInstallType === 'pip') return 'pip';
  if (/[=<>!]=|(?<![=<>!])[<>]/.test(val)) return 'pip';
  const names = val.trim().split(/[\s,]+/);
  const normalize = n => n.toLowerCase().replace(/[-_]/g, '');
  if (names.length > 0 && names.every(n => PIP_PACKAGES.has(n.toLowerCase()) || PIP_PACKAGES.has(normalize(n)))) {
    return 'pip';
  }
  return 'apt';
}

function extractUrlFromBashCmd(text) {
  text = text.trim().replace(/^sudo\s+/i, '');

  // Pattern A:  bash -c "$(curl ... URL)" [@ args] [args]
  // مثلاً: bash -c "$(curl -sL https://.../script.sh)" @ install --database mysql
  let m = text.match(/bash\s+-c\s+["']\$\(\s*curl\s+[^)]*?(https?:\/\/[^\s)'"]+)\s*\)\s*["']\s*(.*)$/i);
  if (m) {
    let rest = (m[2] || '').trim();
    // bash -c idiom: first arg becomes $0, often shown as "@" or "_" or "--"
    if (/^@(\s|$)/.test(rest)) rest = rest.replace(/^@\s*/, '').trim();
    else if (/^_(\s|$)/.test(rest)) rest = rest.replace(/^_\s*/, '').trim();
    else if (/^--(\s|$)/.test(rest)) rest = rest.replace(/^--\s*/, '').trim();
    return { url: m[1], args: rest, isBashScript: true };
  }

  // Pattern B:  bash <(curl ... URL) [args]
  m = text.match(/bash\s+<\(\s*curl\s+[^)]*?(https?:\/\/[^\s)'"]+)\s*\)\s*(.*)$/i);
  if (m) {
    return { url: m[1], args: (m[2] || '').trim(), isBashScript: true };
  }

  // Pattern C:  curl ... URL | bash [-s -- args]
  m = text.match(/curl\s+[^|]*?(https?:\/\/\S+?)\s*\|\s*(?:sudo\s+)?bash(?:\s+-s)?(?:\s+--)?\s*(.*)$/i);
  if (m) {
    return { url: m[1], args: (m[2] || '').trim(), isBashScript: true };
  }

  // Pattern D:  wget -O- URL | bash [-s -- args]
  m = text.match(/wget\s+[^|]*?(https?:\/\/\S+?)\s*\|\s*(?:sudo\s+)?bash(?:\s+-s)?(?:\s+--)?\s*(.*)$/i);
  if (m) {
    return { url: m[1], args: (m[2] || '').trim(), isBashScript: true };
  }

  return null;
}

function generateInstall() {
  let raw = document.getElementById('installInput').value.trim();
  hideInstallError();
  hideInstallOutput();

  if (!raw) {
    showInstallError('لطفاً مقدار را وارد کنید.');
    return;
  }

  // Auto-fix: bash <(curl ...) or curl ... | bash or bash -c "$(curl ...)" @ args
  let extractedArgs = '';
  const extracted = extractUrlFromBashCmd(raw);
  if (extracted) {
    raw = extracted.url;
    extractedArgs = extracted.args || '';
    document.getElementById('installInput').value = raw;
    const hint = document.getElementById('installHintText');
    hint.textContent = extractedArgs
      ? `⚡ URL استخراج شد و آرگومان‌های "${extractedArgs}" حفظ شدند.`
      : '⚡ دستور curl/bash شناسایی شد. URL استخراج و اصلاح شد.';
  }

  const type = selectedInstallType === 'auto' ? detectInstallType(raw) : selectedInstallType;

  let cmd = '', title = '', icon = '', tag = '', note = '';

  if (type === 'github') {
    const result = buildGithubCmd(raw, extractedArgs);
    cmd = result.cmd;
    title = 'دستور نصب از GitHub';
    icon = '⬇️';
    tag = 'VPN-RUN · GITHUB';
    note = result.note;

  } else if (type === 'apt') {
    const pkgs = raw.split(/[\s,]+/).filter(Boolean).join(' ');
    cmd = `vpn-run apt install -y ${pkgs}`;
    title = 'دستور نصب apt';
    icon = '📦';
    tag = 'VPN-RUN · APT';
    note = 'apt اول از mirror ایران (محلی) و در صورت نیاز از VPN رد می‌شود.';

  } else if (type === 'pip') {
    const pkgs = raw.split(/[\s,]+/).filter(Boolean).join(' ');
    cmd = `# اگر pip3 نصب نیست، اول نصب می‌شود
vpn-run bash -c 'command -v pip3 >/dev/null || apt install -y python3-pip; pip3 install --break-system-packages ${pkgs}'`;
    title = 'دستور نصب pip';
    icon = '🐍';
    tag = 'VPN-RUN · PIP';
    note = 'اگر python3-pip نصب نباشد، خودکار نصب می‌شود. سپس پکیج‌ها از طریق VPN دانلود می‌شوند.';

  } else if (type === 'url') {
    cmd = buildUrlDownloadCmd(raw);
    title = 'دستور دانلود';
    icon = '🔗';
    tag = 'VPN-RUN · CURL';
    note = 'دانلود از طریق VPN با retry خودکار و resume برای فایل‌های بزرگ.';
  }

  if (!cmd) {
    showInstallError('نتوانستم دستور تولید کنم. ورودی را بررسی کنید.');
    return;
  }

  currentInstallCmd = cmd;
  showInstallOutput(cmd, title, icon, tag, note, type);
}

/* ── GitHub command builder (uses vpn-run wrapper) ── */
function buildGithubCmd(url, extraArgs = '') {
  url = url.trim();
  const argsSuffix = extraArgs ? ' ' + extraArgs : '';

  // Helper: vpn-run handles all the proxy magic. Download → execute pattern avoids
  // the "bash <(curl ...) hangs with proxied curl" problem.
  const bashScriptCmd = (scriptUrl, args = '') => {
    const filename = scriptUrl.split('/').pop().split('?')[0] || 'install.sh';
    const tmpPath = `/tmp/${filename}`;
    return `vpn-run bash -c 'curl -Ls "${scriptUrl}" -o ${tmpPath} && bash ${tmpPath}${args ? ' ' + args : ''}'`;
  };

  // ── Raw script URL (.sh / .bash / .py) ──
  if (url.includes('raw.githubusercontent.com') || url.includes('raw.github.com') ||
      (url.includes('github.com') && url.includes('/raw/'))) {
    const isScript = /\.(sh|bash|py)(\?.*)?$/.test(url);
    if (isScript) {
      return { cmd: bashScriptCmd(url, extraArgs), note: extraArgs ? `آرگومان "${extraArgs}" به اسکریپت پاس داده می‌شود.` : '' };
    } else {
      const filename = url.split('/').pop().split('?')[0] || 'downloaded_file';
      return {
        cmd: `vpn-run curl -L "${url}" -o /tmp/${filename}`,
        note: ''
      };
    }
  }

  // ── GitHub release direct file URL ──
  if (url.includes('/releases/download/') || url.includes('/releases/latest/download/')) {
    const filename = url.split('/').pop() || 'release_file';
    let extractCmd = '';
    if (filename.endsWith('.tar.gz') || filename.endsWith('.tgz')) {
      extractCmd = ` && tar -xzf /tmp/${filename} -C /usr/local/`;
    } else if (filename.endsWith('.zip')) {
      extractCmd = ` && unzip -o /tmp/${filename} -d /tmp/extracted/`;
    } else if (filename.endsWith('.deb')) {
      extractCmd = ` && dpkg -i /tmp/${filename}`;
    } else if (filename.endsWith('.sh') || filename.endsWith('.bash')) {
      extractCmd = ` && bash /tmp/${filename}${argsSuffix}`;
    }
    return {
      cmd: `vpn-run bash -c 'curl -L "${url}" -o /tmp/${filename}${extractCmd}'`,
      note: ''
    };
  }

  // ── GitHub repo URL → resolve to install script ──
  const repoMatch = url.match(/github\.com\/([^\/]+)\/([^\/\s?#]+)/);
  if (repoMatch) {
    const user = repoMatch[1];
    const repo = repoMatch[2].replace(/\.git$/, '');
    const repoKey = repo.toLowerCase().replace(/_/g, '-');

    // Well-known repos: exact install script + default args
    const wellKnown = {
      '3x-ui':           { script: 'https://raw.githubusercontent.com/mhsanaei/3x-ui/master/install.sh' },
      'x-ui':            { script: 'https://raw.githubusercontent.com/vaxilu/x-ui/master/install.sh' },
      'marzban':         { script: 'https://github.com/Gozargah/Marzban-scripts/raw/master/marzban.sh', args: 'install' },
      'marzban-scripts': { script: 'https://github.com/Gozargah/Marzban-scripts/raw/master/marzban.sh', args: 'install' },
      'marzneshin':      { script: 'https://github.com/marzneshin/Marzneshin/raw/master/script.sh', args: 'install' },
      'marznode':        { script: 'https://raw.githubusercontent.com/marzneshin/marznode/master/script.sh', args: 'install' },
      'marzban-node':    { script: 'https://github.com/Gozargah/Marzban-scripts/raw/master/marzban-node.sh', args: 'install' },
      'hiddify-manager': { script: 'https://raw.githubusercontent.com/hiddify/Hiddify-Manager/main/install.sh' },
      'hiddify':         { script: 'https://raw.githubusercontent.com/hiddify/Hiddify-Manager/main/install.sh' },
      'reality-ezpz':    { script: 'https://raw.githubusercontent.com/aleskxyz/reality-ezpz/master/reality-ezpz.sh' },
      's-ui':            { script: 'https://raw.githubusercontent.com/alireza0/s-ui/master/install.sh' },
    };

    if (wellKnown[repoKey]) {
      const wk = wellKnown[repoKey];
      const finalArgs = extraArgs || wk.args || '';
      return {
        cmd: bashScriptCmd(wk.script, finalArgs),
        note: '✓ ریپو شناخته شده — اسکریپت نصب صحیح به‌طور خودکار انتخاب شد.'
      };
    }

    // ── Smart auto-detect for unknown repos ──
    // Try multiple common script paths in master & main, use the first that exists
    const candidates = [
      `https://raw.githubusercontent.com/${user}/${repo}/master/install.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/main/install.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/master/script.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/main/script.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/master/setup.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/main/setup.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/master/${repo}.sh`,
      `https://raw.githubusercontent.com/${user}/${repo}/main/${repo}.sh`,
    ];

    const urlListBash = candidates.map(u => `    "${u}"`).join(' \\\n');
    const argsForExec = extraArgs ? ` ${extraArgs}` : '';

    const cmd = `vpn-run bash -c '
# 🔍 جستجوی هوشمند اسکریپت نصب در ریپو ${user}/${repo}
SCRIPT_URL=""
for u in \\
${urlListBash} ; do
  CODE=$(curl -sL -o /tmp/_gh_test -w "%{http_code}" "$u")
  if [ "$CODE" = "200" ] && [ -s /tmp/_gh_test ]; then
    FIRST=$(head -1 /tmp/_gh_test)
    case "$FIRST" in
      \\#!*|\\#*|"echo "*|"set "*|"if "*|"export "*|"source "*) SCRIPT_URL="$u"; cp /tmp/_gh_test /tmp/install.sh; break ;;
    esac
  fi
done
rm -f /tmp/_gh_test
if [ -z "$SCRIPT_URL" ]; then
  echo "✗ اسکریپت نصب در مسیرهای متداول پیدا نشد."
  echo "  README ریپو را چک کنید: https://github.com/${user}/${repo}"
  exit 1
fi
echo "✓ اسکریپت پیدا شد: $SCRIPT_URL"
bash /tmp/install.sh${argsForExec}'`;

    return {
      cmd,
      note: `این دستور خودکار ۸ مسیر متداول را تست می‌کند: install.sh، script.sh، setup.sh، ${repo}.sh — در branch master و main. اگر هیچ‌کدام پیدا نشد، URL درست را از README ریپو پیدا کنید.`
    };
  }

  return {
    cmd: `vpn-run curl -Ls "${url}" -o /tmp/gh_download`,
    note: ''
  };
}

function buildUrlDownloadCmd(url) {
  const filename = url.split('/').pop().split('?')[0] || 'downloaded_file';
  const ext = filename.split('.').pop().toLowerCase();
  let extra = '';
  if (ext === 'sh' || ext === 'bash') {
    extra = ` && bash /tmp/${filename}`;
  } else if (filename.endsWith('.tar.gz') || filename.endsWith('.tgz')) {
    extra = ` && tar -xzf /tmp/${filename} -C /tmp/`;
  } else if (ext === 'deb') {
    extra = ` && dpkg -i /tmp/${filename}`;
  }
  // -C - = resume,  --retry 5 = retry 5 times,  --retry-delay 3 = wait 3s between retries
  // --max-time 1200 = max 20min for huge files
  return `vpn-run bash -c 'curl -L -C - --retry 5 --retry-delay 3 --max-time 1200 "${url}" -o /tmp/${filename}${extra}'`;
}

