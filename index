/* ══════════════════════════════════════════════
   SYNTAX HIGHLIGHTING
══════════════════════════════════════════════ */
function highlightFullCmd(text) {
  const lines = text.split('\n');
  return lines.map((line) => {
    const escaped = escHtml(line);
    if (escaped === 'EOF' || escaped === 'ENDOFFILE') {
      return `<span class="heredoc-eof">${escaped}</span>`;
    }
    if (line.startsWith('echo ') || line.startsWith('rm -f') || line.startsWith('tee ') ||
        line.startsWith('deb ') || line.startsWith('unset ') || line.startsWith('apt ') ||
        line.startsWith('cat ') || line.startsWith('systemctl') || line.startsWith('sed ') ||
        line.startsWith('curl ') || line.startsWith('sleep ') || line.startsWith('pkill ') ||
        line.startsWith('dpkg ')) {
      return `<span class="heredoc-cmd">${escaped}</span>`;
    }
    if (line.trim().startsWith('"') || line.trim().startsWith('{') || line.trim().startsWith('}') ||
        line.trim().startsWith('[') || line.trim().startsWith(']')) {
      return syntaxHighlight(escaped);
    }
    return escaped;
  }).join('\n');
}

function highlightBashCmd(text) {
  const lines = text.split('\n');
  return lines.map(line => {
    if (line.startsWith('#')) {
      return `<span class="bash-comment">${escHtml(line)}</span>`;
    }
    const out = [];
    let buf = '';
    const flushBuf = () => { if (buf) { out.push(escHtml(buf)); buf = ''; } };
    let i = 0;
    const cmdMatch = line.match(/^(curl|wget|git|apt|pip3|bash|dpkg|tar|unzip|mkdir|cd|chmod|systemctl|sed|echo|cat|tee|printf|export|unset)([\s|$])/);
    if (cmdMatch) {
      out.push(`<span class="bash-cmd">${escHtml(cmdMatch[1])}</span>`);
      i = cmdMatch[1].length;
    }
    while (i < line.length) {
      const ch = line[i];
      if (ch === '"') {
        flushBuf();
        let j = i + 1;
        while (j < line.length && line[j] !== '"') j++;
        out.push('"<span class="bash-str">' + escHtml(line.substring(i + 1, j)) + '</span>' + (j < line.length ? '"' : ''));
        i = (j < line.length) ? j + 1 : j;
        continue;
      }
      if (ch === '-' && (i === 0 || /\s/.test(line[i - 1]))) {
        const flagMatch = line.substring(i).match(/^(--[a-z0-9-]+|-[a-zA-Z]+)(?=\s|=|$)/);
        if (flagMatch) {
          flushBuf();
          out.push(`<span class="bash-flag">${escHtml(flagMatch[1])}</span>`);
          i += flagMatch[1].length;
          continue;
        }
      }
      buf += ch;
      i++;
    }
    flushBuf();
    return out.join('');
  }).join('\n');
}

function syntaxHighlight(json) {
  if (!json.includes('&lt;') && !json.includes('&quot;')) {
    json = json.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  return json.replace(
    /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g,
    m => {
      let cls = 'json-number';
      if (/^"/.test(m)) cls = /:$/.test(m) ? 'json-key' : 'json-string';
      else if (/true|false/.test(m)) cls = 'json-bool';
      else if (/null/.test(m)) cls = 'json-null';
      return `<span class="${cls}">${m}</span>`;
    }
  );
}

/* ══════════════════════════════════════════════
   CONFIG EXTRACTION STRATEGIES
══════════════════════════════════════════════ */
function tryEOF(s) {
  const re = /<<\s*['"]?(\w+)['"]?\s*\n([\s\S]*?)\n\1\s*$/m;
  const m = s.match(re);
  if (m) return m[2].trim();
  const re2 = /<<\s*['"]?(\w+)['"]?\s*\n([\s\S]*?)\n\1/;
  const m2 = s.match(re2);
  if (m2) return m2[2].trim();
  return null;
}

function tryJSON(s) {
  const trimmed = s.trim();
  if (trimmed.startsWith('{') || trimmed.startsWith('[')) {
    return extractBalanced(trimmed);
  }
  return null;
}

function tryVlessLink(s) {
  const m = s.match(/vless:\/\/([^\s@]+)@([^:\s]+):(\d+)[?]([^\s#]*)(?:#.*)?/);
  if (!m) return null;
  const uuid = m[1], host = m[2], port = parseInt(m[3]);
  const params = parseQuery(m[4]);
  const security = params.security || 'none';
  const network  = params.type || 'tcp';
  const path     = params.path ? decodeURIComponent(params.path) : '/';
  const sni      = params.sni || params.host || host;
  const fp       = params.fp || '';
  const alpn     = params.alpn ? decodeURIComponent(params.alpn).split(',') : [];
  const headerHost = params.host || host;
  const streamSettings = buildStreamSettings(network, security, path, sni, headerHost, fp, alpn, '', '');
  return {
    log: { loglevel: 'warning' },
    inbounds: [{ port: 1080, protocol: 'socks', listen: '127.0.0.1', settings: { auth: 'noauth' } }],
    outbounds: [{
      protocol: 'vless',
      settings: { vnext: [{ address: host, port, users: [{ id: uuid, encryption: 'none' }] }] },
      streamSettings
    }, { protocol: 'freedom', tag: 'direct' }]
  };
}

function tryVmessLink(s) {
  const m = s.match(/vmess:\/\/([A-Za-z0-9+/=]+)/);
  if (!m) return null;
  let v;
  try { v = JSON.parse(atob(m[1])); } catch(e) { return null; }
  const host = v.add || '', port = parseInt(v.port) || 443, uuid = v.id || '';
  const alterId = parseInt(v.aid) || 0, net = v.net || 'tcp', tls = v.tls || '';
  const path = v.path || '/', sni = v.sni || v.host || host, host2 = v.host || host;
  const fp = v.fp || '';
  const alpn = v.alpn ? (typeof v.alpn === 'string' ? v.alpn.split(',') : v.alpn) : [];
  const streamSettings = buildStreamSettings(net, tls, path, sni, host2, fp, alpn, '', '');
  return {
    log: { loglevel: 'warning' },
    inbounds: [{ port: 1080, protocol: 'socks', listen: '127.0.0.1', settings: { auth: 'noauth' } }],
    outbounds: [{
      protocol: 'vmess',
      settings: { vnext: [{ address: host, port, users: [{ id: uuid, alterId, security: 'auto' }] }] },
      streamSettings
    }, { protocol: 'freedom', tag: 'direct' }]
  };
}

function tryTrojanLink(s) {
  const m = s.match(/trojan:\/\/([^@\s]+)@([^:\s]+):(\d+)[?]?([^\s#]*)(?:#.*)?/);
  if (!m) return null;
  const password = m[1], host = m[2], port = parseInt(m[3]);
  const params = parseQuery(m[4] || '');
  const security = params.security || 'tls', network = params.type || 'tcp';
  const path = params.path ? decodeURIComponent(params.path) : '/';
  const sni = params.sni || host, fp = params.fp || '';
  const alpn = params.alpn ? decodeURIComponent(params.alpn).split(',') : [];
  const streamSettings = buildStreamSettings(network, security, path, sni, host, fp, alpn, '', '');
  return {
    log: { loglevel: 'warning' },
    inbounds: [{ port: 1080, protocol: 'socks', listen: '127.0.0.1', settings: { auth: 'noauth' } }],
    outbounds: [{
      protocol: 'trojan',
      settings: { servers: [{ address: host, port, password }] },
      streamSettings
    }, { protocol: 'freedom', tag: 'direct' }]
  };
}

function trySsLink(s) {
  const m = s.match(/ss:\/\/([A-Za-z0-9+/=]+)(?:@([^:\s]+):(\d+))?(?:#.*)?/);
  if (!m) return null;
  let decoded = '';
  try { decoded = atob(m[1]); } catch(e) { return null; }
  let method2, password, host, port;
  if (m[2]) {
    const cp = decoded.indexOf(':');
    method2 = decoded.substring(0, cp);
    password = decoded.substring(cp + 1);
    host = m[2]; port = parseInt(m[3]);
  } else {
    const atI = decoded.lastIndexOf('@');
    if (atI === -1) return null;
    const methodPass = decoded.substring(0, atI);
    const hostPort   = decoded.substring(atI + 1);
    const cp = methodPass.indexOf(':');
    method2  = methodPass.substring(0, cp);
    password = methodPass.substring(cp + 1);
    const hp = hostPort.lastIndexOf(':');
    host = hostPort.substring(0, hp);
    port = parseInt(hostPort.substring(hp + 1));
  }
  return {
    log: { loglevel: 'warning' },
    inbounds: [{ port: 1080, protocol: 'socks', listen: '127.0.0.1', settings: { auth: 'noauth' } }],
    outbounds: [{
      protocol: 'shadowsocks',
      settings: { servers: [{ address: host, port, method: method2, password }] }
    }, { protocol: 'freedom', tag: 'direct' }]
  };
}

function tryBracketExtract(s) {
  const start = s.indexOf('{');
  if (start === -1) return null;
  return extractBalanced(s.substring(start));
}

/* ══════════════════════════════════════════════
   HELPERS
══════════════════════════════════════════════ */
function cleanMarkdown(s) {
  if (!s) return s;
  return s.replace(/\[([^\]]+)\]\([^)]+\)/g, (match, text) => text.trim()).trim();
}

function cleanMarkdownInJSON(obj) {
  if (typeof obj === 'string') return cleanMarkdown(obj);
  if (Array.isArray(obj)) return obj.map(cleanMarkdownInJSON);
  if (obj && typeof obj === 'object') {
    const out = {};
    for (const k of Object.keys(obj)) out[k] = cleanMarkdownInJSON(obj[k]);
    return out;
  }
  return obj;
}

function extractBalanced(s) {
  let depth = 0, inStr = false, escape = false, start = -1;
  for (let i = 0; i < s.length; i++) {
    const c = s[i];
    if (escape) { escape = false; continue; }
    if (c === '\\' && inStr) { escape = true; continue; }
    if (c === '"') { inStr = !inStr; continue; }
    if (inStr) continue;
    if (c === '{') { if (depth === 0) start = i; depth++; }
    else if (c === '}') { depth--; if (depth === 0 && start !== -1) return s.substring(start, i + 1); }
  }
  return null;
}

function parseQuery(qs) {
  const out = {};
  if (!qs) return out;
  qs.replace(/^\?/, '').split('&').forEach(pair => {
    const [k, v] = pair.split('=');
    if (k) out[decodeURIComponent(k)] = v ? decodeURIComponent(v) : '';
  });
  return out;
}

function buildStreamSettings(network, security, path, sni, host, fp, alpn, headerType, grpcSvcName) {
  const ss = { network, security };
  if (security === 'tls') {
    ss.tlsSettings = { serverName: sni };
    if (alpn && alpn.length) ss.tlsSettings.alpn = alpn;
    if (fp) ss.tlsSettings.fingerprint = fp;
  } else if (security === 'reality') {
    ss.realitySettings = { serverName: sni };
    if (fp) ss.realitySettings.fingerprint = fp;
  }
  if (network === 'ws') {
    ss.wsSettings = { path };
    if (host) ss.wsSettings.headers = { Host: host };
  } else if (network === 'grpc') {
    ss.grpcSettings = { serviceName: grpcSvcName || path.replace(/^\//, '') };
  } else if (network === 'h2' || network === 'http') {
    ss.httpSettings = { path, host: host ? [host] : [] };
  } else if (network === 'tcp' && headerType === 'http') {
    ss.tcpSettings = { header: { type: 'http', request: { path: [path], headers: { Host: [host] } } } };
  } else if (network === 'kcp' || network === 'mkcp') {
    ss.kcpSettings = { header: { type: headerType || 'none' } };
  } else if (network === 'quic') {
    ss.quicSettings = { header: { type: headerType || 'none' } };
  }
  return ss;
}

function extractInfo(obj) {
  const rows = [];
  try {
    const outs = obj.outbounds || [];
    const out  = outs.find(o => o.protocol && o.protocol !== 'freedom' && o.protocol !== 'blackhole') || outs[0];
    if (!out) return rows;
    const proto = out.protocol || '—';
    const ss    = out.streamSettings || {};
    const net   = ss.network || 'tcp';
    const sec   = ss.security || 'none';
    rows.push({ key: 'پروتکل', val: proto.toUpperCase(), hl: true });
    rows.push({ key: 'شبکه (transport)', val: net.toUpperCase() });
    rows.push({ key: 'امنیت', val: sec === 'none' ? 'بدون رمزنگاری' : sec.toUpperCase() });
    const settings = out.settings || {};
    let addr = '—', port = '—', uid = '—';
    if (settings.vnext && settings.vnext[0]) {
      addr = settings.vnext[0].address;
      port = settings.vnext[0].port;
      const user = (settings.vnext[0].users || [])[0] || {};
      uid = user.id || user.uuid || '—';
    } else if (settings.servers && settings.servers[0]) {
      addr = settings.servers[0].address;
      port = settings.servers[0].port;
      uid  = settings.servers[0].password || '—';
    }
    rows.push({ key: 'سرور', val: addr });
    rows.push({ key: 'پورت', val: String(port) });
    if (uid !== '—') rows.push({ key: proto === 'trojan' ? 'پسورد' : 'UUID', val: uid });
    if (ss.tlsSettings)     rows.push({ key: 'SNI', val: ss.tlsSettings.serverName || '—' });
    if (ss.realitySettings) rows.push({ key: 'SNI (Reality)', val: ss.realitySettings.serverName || '—' });
    if (ss.wsSettings)      rows.push({ key: 'WebSocket Path', val: ss.wsSettings.path || '/' });
    if (ss.grpcSettings)    rows.push({ key: 'gRPC Service', val: ss.grpcSettings.serviceName || '—' });
    const inb = (obj.inbounds || [])[0];
    if (inb) rows.push({ key: 'Inbound (SOCKS5)', val: `${inb.listen || '127.0.0.1'}:${inb.port}` });
  } catch(e) {}
  return rows;
}

function detectProtocolShort(obj) {
  try {
    const outs = obj.outbounds || [];
    const out  = outs.find(o => o.protocol !== 'freedom' && o.protocol !== 'blackhole') || outs[0];
    if (!out) return null;
    const ss = out.streamSettings || {};
    return [
      out.protocol?.toUpperCase(),
      ss.network?.toUpperCase(),
      ss.security && ss.security !== 'none' ? ss.security.toUpperCase() : null
    ].filter(Boolean).join(' + ');
  } catch(e){ return null; }
}

function flashBtn(id, label) {
  const btn = document.getElementById(id);
  const orig = btn.innerHTML;
  btn.classList.add('copied');
  btn.textContent = label;
  setTimeout(() => { btn.classList.remove('copied'); btn.innerHTML = orig; }, 2000);
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

